# PHPStan configuration for laranail/toolkit (PHPStan 2.x)
# Larastan + strict-rules are introduced in a later phase; the baseline below
# captures inherited debt and is ratcheted down per cleaned module.

includes:
    - phpstan-baseline.neon

parameters:
    level: 8

    paths:
        - src

    bootstrapFiles:
        - vendor/autoload.php

    ignoreErrors:
        # Laravel facades / magic helpers resolve dynamically.
        - '#Call to an undefined method Illuminate\\.*#'
        - '#Access to an undefined property Illuminate\\.*#'
        - '#Access to an undefined property stdClass::\$.*#'

    excludePaths:
        - tests/*/Fixtures/*
        - vendor/*

    reportUnmatchedIgnoredErrors: false

    parallel:
        jobSize: 20
        maximumNumberOfProcesses: 4
        minimumNumberOfJobsPerProcess: 2
