{
    "name": "laranail/toolkit",
    "description": "Laranail Toolkit — a comprehensive, security-first Swiss-army toolkit for Laravel: utilities, traits, middleware, macros, LLM providers, and feature modules for day-to-day Laravel development.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "laranail",
        "toolkit",
        "utilities",
        "traits",
        "middleware",
        "macros",
        "llm"
    ],
    "homepage": "https://opensource.simtabi.com/toolkit/",
    "authors": [
        {
            "name": "Imani Manyara",
            "email": "imani@simtabi.com",
            "homepage": "https://www.imanimanyara.com",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/laranail/toolkit/issues",
        "source": "https://github.com/laranail/toolkit",
        "docs": "https://opensource.simtabi.com/toolkit/docs/"
    },
    "require": {
        "php": "^8.4.1",
        "ext-fileinfo": "*",
        "ext-mbstring": "*",
        "illuminate/cache": "^13.0",
        "illuminate/console": "^13.0",
        "illuminate/contracts": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/filesystem": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/pagination": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/support": "^13.0",
        "illuminate/validation": "^13.0",
        "intervention/image": "^4.1",
        "laranail/console": "dev-main",
        "openai-php/client": "^0.20.0"
    },
    "require-dev": {
        "infection/infection": "^0.33",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.0",
        "rector/rector": "^2.0",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../tools/console",
            "options": {
                "symlink": true
            }
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Simtabi\\Laranail\\Toolkit\\": "src/"
        },
        "files": [
            "helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Simtabi\\Laranail\\Toolkit\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "infection/extension-installer": false
        }
    },
    "scripts": {
        "test": "pest",
        "test:coverage": "pest --coverage --min=85",
        "test:mutation": "infection --threads=max --no-progress",
        "analyse": "phpstan analyse",
        "format": "pint"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Simtabi\\Laranail\\Toolkit\\Providers\\ToolkitServiceProvider"
            ],
            "aliases": {
                "Toolkit": "Simtabi\\Laranail\\Toolkit\\Facades\\Toolkit",
                "Avatar": "Simtabi\\Laranail\\Toolkit\\Modules\\Avatar\\Avatar",
                "Gravatar": "Simtabi\\Laranail\\Toolkit\\Modules\\Gravatar\\Gravatar",
                "Captcha": "Simtabi\\Laranail\\Toolkit\\Modules\\Captcha\\Captcha",
                "Archiver": "Simtabi\\Laranail\\Toolkit\\Modules\\Archiver\\Archiver"
            }
        }
    }
}
